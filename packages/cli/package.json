    "url": "git+https://github.com/AIGraphia/aigp.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/AIGraphia/aigp/issues"
  },
  "homepage": "https://github.com/AIGraphia/aigp/tree/main/packages/cli",
  "author": "AIGP Contributors",
  "engines": {
    "node": ">=18"
