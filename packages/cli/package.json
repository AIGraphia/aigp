{
  "name": "@aigraphia/cli",
  "version": "1.0.1",
  "description": "CLI tool for AIGP",
  "type": "module",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aigp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aigraphia/export": "workspace:*",
    "@aigraphia/layout": "workspace:*",
    "@aigraphia/plugins": "workspace:*",
    "@aigraphia/protocol": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
